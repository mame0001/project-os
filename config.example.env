# =============================================================
# Project-OS 設定檔範例 / config example
# 用法：cp config.example.env .env  然後填入你自己的值
# Usage: cp config.example.env .env  then fill in your own values
# ⚠️ .env 已被 .gitignore 排除，不會上傳。請勿把真實 token 寫進本檔。
# =============================================================

# ---- Obsidian ----
# 你的 vault 根目錄絕對路徑 / absolute path to your Obsidian vault root
VAULT_PATH="$HOME/Obsidian/MyVault"
# vault 名稱（用於 obsidian:// 連結）/ vault name for obsidian:// URIs
VAULT_NAME="MyVault"

# ---- Notion ----
# 內部整合 token：https://www.notion.so/my-integrations 建立後填入
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN="secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# 要建立資料庫的父頁面 ID（把該頁分享給你的 integration）
# Parent page ID where databases will be created (share the page with your integration)
NOTION_PARENT_PAGE_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Google Drive (rclone) ----
# rclone remote 名稱 / rclone remote name (see: rclone config)
RCLONE_REMOTE="gdrive"
# Drive 中放專案的根資料夾名稱 / root folder name for projects in Drive
DRIVE_ROOT="ProjectsRoot"
